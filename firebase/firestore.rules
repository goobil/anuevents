rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isModerator() {
      return isSignedIn() && request.auth.token.role in ['moderator','admin'];
    }

    // Public reads for approved events only
    match /events/{eventId} {
      allow read: if resource.data.status == 'approved';
      allow create: if isSignedIn() && request.resource.data.status == 'pending' && request.resource.data.createdBy == request.auth.uid;
      allow update: if isModerator() || (isSignedIn() && resource.data.createdBy == request.auth.uid && resource.data.status != 'approved');
      allow delete: if isModerator();
    }

    match /users/{userId}/bookmarks/{bookmarkId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /featuredSlots/{id} {
      allow read: if true;
      allow write: if isModerator();
    }

    // Default deny
    match /{documents=**} {
      allow read, write: if false;
    }
  }
}
