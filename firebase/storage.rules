rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Allow read of public approved posters (optional: you might host approved posters under a different bucket/path)
    match /posters/{userId}/{allPaths=**} {
      // anyone can read posters (public)
      allow read: if true;

      // only the authenticated owner may upload/update/delete their poster objects
      allow write: if request.auth != null && request.auth.uid == userId
        // basic safety checks: require content type to start with image/
        && request.resource.contentType.matches('image/.*')
        // limit file size to a reasonable cap (e.g., 10MB)
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
